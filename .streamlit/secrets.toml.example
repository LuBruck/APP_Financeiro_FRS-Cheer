# Copie este arquivo para `.streamlit/secrets.toml` e preencha os valores reais.
# NUNCA commite o secrets.toml — ele já está no .gitignore.

# ---------------------------------------------------------------------------
# 1) Service Account (Camada 2: App → Google APIs)
# Cole aqui o conteúdo do JSON da Service Account gerada no Google Cloud Console.
# ---------------------------------------------------------------------------
[google_service_account]
type = "service_account"
project_id = "seu-projeto-gcp"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "service-account@seu-projeto-gcp.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"

# ---------------------------------------------------------------------------
# 2) Google OIDC para st.login() (Camada 1: Usuário → App)
# Valores vêm do "OAuth 2.0 Client" criado no Google Cloud Console.
# ---------------------------------------------------------------------------
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "gere-um-segredo-aleatorio-de-pelo-menos-32-bytes-aqui"
client_id = "...apps.googleusercontent.com"
client_secret = "..."
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---------------------------------------------------------------------------
# 3) Whitelist de usuários autorizados
# Chave = email Google do usuário; valor = "admin" ou "assistant".
# ---------------------------------------------------------------------------
[authorized_users]
"diretor@exemplo.com" = "admin"
# "assistente1@exemplo.com" = "assistant"
# "assistente2@exemplo.com" = "assistant"

# ---------------------------------------------------------------------------
# 4) IDs dos recursos Google (não são sensíveis, mas ficam aqui por conveniência)
# ---------------------------------------------------------------------------
[google_resources]
spreadsheet_id = "1AbCdEf..."      # ID da planilha mestre
drive_folder_id = "1XyZw..."       # ID da pasta raiz "Financeiro-Furiosos-Cheer"
